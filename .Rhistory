get_blockpairwise_dll_path <- function() {
dll <- getLoadedDLLs()[["blockpairwise"]]
out <- tryCatch(
dll[["path"]],
error = function(e) NULL
)
if (is.null(out)) {
out <- tryCatch(
unclass(dll)$path,
error = function(e) NULL
)
}
out
}
