# -----------------------------
# 1. Dominio unitario [0,1]^2
# -----------------------------
n <- 10000
coords <- cbind(
x = runif(n),
y = runif(n)
)
# -----------------------------
# 2. Covariables
# OJO: incluye intercepto explícito
# -----------------------------
X <- cbind(
Intercept = 1,
x1 = coords[, 1],
x2 = coords[, 2]
)
beta_true <- c(
beta_0 = 1.0,
beta_1 = 2.0,
beta_2 = -1.5
)
trend <- as.numeric(X %*% beta_true)
# -----------------------------
# 3. Parámetros espaciales verdaderos
# -----------------------------
sill_true   <- 1
range_true  <- 0.15
nugget_true <- 0.5
smooth_true <- 0.5
sill_geo <- sill_true + nugget_true
scale_geo <- range_true
nugget_geo <- nugget_true/sill_geo
eps <- GeoSimapprox(
coordx = coords,
corrmodel = "Matern",
model = "Gaussian",
method="TB",
param = list(
mean   = 0.5,
sill   = sill_geo,
scale  = scale_geo,
nugget = nugget_geo,
smooth = smooth_true
),
nrep = 1)$data
#y <- trend + as.numeric(eps)
y <- as.numeric(eps)
# -----------------------------
# 4. Ajuste con tu función
# -----------------------------
fit <- fit_blockpairwise(
y = y,
coords = coords,
#X = X,
start_beta = 0.5,
start_cov = c(
sill   = sill_true,
range  = range_true,
nugget = nugget_true
),
fixed_param = c(smooth = 0.5),
likelihood = "conditional",
optimizer = "BFGS",
cblocks = "kmeans",
nblocks = 1,
fweight = "nn",
nnk = 4,
control = list(maxit = 300)
)
fit
fit$nnk
summary(fit)
