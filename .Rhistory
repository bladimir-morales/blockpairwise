bp_regular_grid_dims <- function(nblocks) {
divs <- which(nblocks %% seq_len(nblocks) == 0L)
nx <- divs[which.min(abs(divs - sqrt(nblocks)))]
ny <- nblocks / nx
c(nx = as.integer(nx), ny = as.integer(ny))
}
