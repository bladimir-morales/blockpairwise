precomp <- prepare_bcl_data(
data = bd,
cblocks = "kmeans",
nblocks = 4,
fweight = "nn",
nnk = 12
)
lower <- c(-4, 1e-10, 1e-10, 0, 0.2)
upper <- c(4, var(bd$z)+10, 1500, var(bd$z), 4)
par0 <- c(mean(bd$z), var(bd$z), 150, 0, 0.5)
fit <- fit_blockpairwise(
data = bd,
par = par0,
lower = lower,
upper = upper,
free_idx = c(1,2,3,5),
likelihood = "marginal",
precomp = precomp
)
fit
summary(fit)
